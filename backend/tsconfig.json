{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@taxi/common": ["libs/common/src"],
      "@taxi/common/*": ["libs/common/src/*"],
      "@taxi/database": ["libs/database/src"],
      "@taxi/database/*": ["libs/database/src/*"],
      "@taxi/events": ["libs/events/src"],
      "@taxi/events/*": ["libs/events/src/*"]
    }
  }
}

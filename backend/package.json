{
  "name": "@taxi/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:all": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:identity\" \"npm run dev:ride\" \"npm run dev:payment\" \"npm run dev:location\" \"npm run dev:notification\"",
    "dev:gateway": "nest start api-gateway --watch",
    "dev:auth": "nest start auth-service --watch",
    "dev:identity": "nest start identity-service --watch",
    "dev:ride": "nest start ride-service --watch",
    "dev:payment": "nest start payment-service --watch",
    "dev:location": "nest start location-service --watch",
    "dev:notification": "nest start notification-service --watch",
    "build": "nest build",
    "build:prod": "nest build api-gateway && nest build auth-service && nest build identity-service && nest build ride-service && nest build payment-service && nest build location-service && nest build notification-service",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.0",
    "@nestjs/websockets": "^10.4.0",
    "amqplib": "^0.10.4",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/amqplib": "^0.10.5",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.0"
  }
}

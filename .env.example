# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://taxi:taxi_secret@localhost:5432/taxi_platform?schema=public
POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi_secret
POSTGRES_DB=taxi_platform

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URL=amqp://taxi:taxi_secret@localhost:5672

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-256-bit-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OTP ────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
SMS_PROVIDER=mock

# ─── Services ───────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
IDENTITY_SERVICE_PORT=3002
RIDE_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
LOCATION_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# ─── Maps ───────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# ─── Payments (Uzbekistan) ──────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_API_URL=https://checkout.paycom.uz/api
CLICK_API_URL=https://api.click.uz/v2/merchant
CLICK_MERCHANT_USER_ID=
PAYMENT_MOCK=true
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# ─── Firebase (FCM) ─────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── KYC / Identity ─────────────────────────────────────────
KYC_OCR_PROVIDER=mock
KYC_FACE_MATCH_THRESHOLD=0.85
KYC_LIVENESS_THRESHOLD=0.90

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
DEFAULT_CURRENCY=UZS
DEFAULT_LOCALE=uz
